---
import type { PublicEvent } from '~/lib/calendar';

interface Props {
  events: PublicEvent[];
  emptyMessage?: string;
}

const { events, emptyMessage = 'No upcoming events. Check back soon.' } = Astro.props;

function formatDate(iso: string) {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', {
    weekday: 'short',
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

{
  events.length === 0 ? (
    <p class="empty-state">{emptyMessage}</p>
  ) : (
    <ul class="event-list">
      {events.map((event) => (
        <li class="event-row">
          <div class="event-date">{formatDate(event.start)}</div>
          <div class="event-body">
            <h3 class="event-title">{event.title}</h3>
            {event.time && <p class="event-time">{event.time}</p>}
            {event.location && <p class="event-location">{event.location}</p>}
            {event.description && <p class="event-description">{event.description}</p>}
            {event.info && (
              <a href={event.info} class="event-info-link" target="_blank" rel="noopener noreferrer">
                More info →
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
  )
}

<style>
  .event-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .event-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
    margin: 0;
  }

  .event-row:last-child {
    border-bottom: none;
  }

  @media (max-width: 600px) {
    .event-row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }

  .event-date {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-accent);
  }

  .event-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    margin: 0 0 var(--space-2) 0;
  }

  .event-time,
  .event-location {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 var(--space-1) 0;
  }

  .event-description {
    margin: var(--space-2) 0 var(--space-2) 0;
  }

  .event-info-link {
    font-size: 0.95rem;
  }

  .empty-state {
    color: var(--color-text-muted);
    font-style: italic;
    padding: var(--space-5) 0;
  }
</style>
