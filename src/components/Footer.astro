---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-name">Will Wheeler</p>
    <ul class="footer-social">
      <li>
        <a href="https://www.facebook.com/willfulbard" target="_blank" rel="noopener noreferrer">
          Facebook
        </a>
      </li>
      <li>
        <a href="https://www.instagram.com/willfulbard/" target="_blank" rel="noopener noreferrer">
          Instagram
        </a>
      </li>
    </ul>
    <p class="footer-copyright">© {year} Will Wheeler</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    padding: var(--space-5) 0;
    margin-top: var(--space-8);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin: 0;
  }

  .footer-social {
    display: flex;
    gap: var(--space-4);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-social a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    text-decoration: none;
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  .footer-copyright {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin: 0;
  }
</style>
