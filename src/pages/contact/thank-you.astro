---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You" description="Thanks for your inquiry. Will will be in touch soon.">
  <section class="container section thank-you">
    <h1>Thank you</h1>
    <p class="lede">
      Your message is on its way. Will reads every inquiry personally and will be in touch
      as soon as he can.
    </p>
    <p>
      In the meantime, you might enjoy:
    </p>
    <ul class="links">
      <li><a href="/events/">Upcoming shows</a></li>
      <li><a href="/projects/">Projects and ensembles</a></li>
      <li><a href="/">Back to the home page</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .thank-you {
    max-width: var(--content-width);
  }

  .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .links {
    list-style: none;
    padding: 0;
    margin-top: var(--space-3);
  }

  .links li {
    margin-bottom: var(--space-2);
  }
</style>
