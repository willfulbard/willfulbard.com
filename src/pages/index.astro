---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import EventList from '~/components/EventList.astro';
import { getCollection } from 'astro:content';
import { getUpcomingEvents } from '~/lib/calendar';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const events = await getUpcomingEvents();
const upcomingEvents = events.slice(0, 5);
---

<BaseLayout title="Will Wheeler">
  <section class="hero-cover">
    <div class="hero-cover-image" aria-hidden="true"></div>
    <div class="hero-cover-overlay"></div>
    <div class="container hero-cover-content">
      <h1>Will Wheeler</h1>
      <p class="tagline">Living music from old roots</p>
      <div class="hero-ctas">
        <a href="/about/" class="button">About Will</a>
        <a href="/events/" class="button button-primary">Upcoming Shows</a>
      </div>
    </div>
  </section>

  <section class="section about-teaser">
    <div class="container">
      <p class="lede">
        Will Wheeler is a guitarist, fiddler, and dancer playing traditional music from around
        the world — Irish, Quebecoise, contra dance, and beyond — in service of the dance floor and
        the community that gathers around it.
      </p>
      <p>
        <a href="/about/">Read more →</a>
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Upcoming Events</h2>
      <EventList events={upcomingEvents} />
      {events.length > 5 && (
        <p style="margin-top: var(--space-4);">
          <a href="/events/">All events →</a>
        </p>
      )}
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="section">
      <div class="container">
        <h2>Featured Projects</h2>
        <div class="project-grid">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
        <p style="margin-top: var(--space-4);">
          <a href="/projects/">All projects →</a>
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-cover {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 560px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: calc(-1 * var(--space-3));
  }

  .hero-cover-image {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero_alt.jpg');
    background-size: cover;
    background-position: center 20%;
    background-color: var(--color-bg-alt);
  }

  .hero-cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(45, 42, 38, 0) 0%,
      rgba(45, 42, 38, 0.1) 50%,
      rgba(45, 42, 38, 0.85) 100%
    );
  }

  .hero-cover-content {
    position: relative;
    z-index: 1;
    color: var(--color-bg);
    padding-bottom: var(--space-7);
  }

  .hero-cover-content h1 {
    color: var(--color-bg);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin-bottom: var(--space-3);
  }

  .tagline {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    color: rgba(250, 248, 243, 0.92);
    margin-bottom: var(--space-5);
    max-width: none;
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero-ctas :global(.button) {
    border-color: var(--color-bg);
    color: var(--color-bg);
  }

  .hero-ctas :global(.button:hover) {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .hero-ctas :global(.button-primary) {
    background: var(--color-bg);
    color: var(--color-text);
    border-color: var(--color-bg);
  }

  .hero-ctas :global(.button-primary:hover) {
    background: var(--color-bg-alt);
    color: var(--color-text);
  }

  .about-teaser .lede {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--color-text);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }
</style>
