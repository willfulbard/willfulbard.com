---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
const { name, style, ensemble, members, hero, links } = project.data;
---

<BaseLayout title={name}>
  <section class:list={['project-cover', { 'project-cover-empty': !hero }]}>
    {
      hero && (
        <div
          class="project-cover-image"
          style={`background-image: url(${hero})`}
          aria-hidden="true"
        />
      )
    }
    <div class="project-cover-overlay"></div>
    <div class="container project-cover-content">
      <p class="project-meta">{style} · {ensemble}</p>
      <h1>{name}</h1>
    </div>
  </section>

  <article class="container section project-page">
    <div class="project-grid">
      <div class="project-content">
        <Content />

        {
          links && (links.bandcamp || links.spotify || links.youtube || links.website) && (
            <section class="project-links">
              <h2>Listen & Follow</h2>
              <ul>
                {links.bandcamp && (
                  <li>
                    <a href={links.bandcamp} target="_blank" rel="noopener noreferrer">
                      Bandcamp
                    </a>
                  </li>
                )}
                {links.spotify && (
                  <li>
                    <a href={links.spotify} target="_blank" rel="noopener noreferrer">
                      Spotify
                    </a>
                  </li>
                )}
                {links.youtube && (
                  <li>
                    <a href={links.youtube} target="_blank" rel="noopener noreferrer">
                      YouTube
                    </a>
                  </li>
                )}
                {links.website && (
                  <li>
                    <a href={links.website} target="_blank" rel="noopener noreferrer">
                      Website
                    </a>
                  </li>
                )}
              </ul>
            </section>
          )
        }
      </div>

      <aside class="project-sidebar">
        <h2>Members</h2>
        <ul class="member-list">
          {
            members.map((member) => (
              <li>
                <strong>{member.name}</strong>
                <span class="member-instruments">{member.instruments.join(', ')}</span>
                {member.note && <span class="member-note">{member.note}</span>}
              </li>
            ))
          }
        </ul>
      </aside>
    </div>

    <p class="back-link">
      <a href="/projects/">← All projects</a>
    </p>
  </article>
</BaseLayout>

<style>
  .project-page {
    padding-left: var(--space-4);
    padding-right: var(--space-4);
  }

  .project-cover {
    position: relative;
    width: 100%;
    height: 60vh;
    min-height: 400px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: calc(-1 * var(--space-3));
  }

  .project-cover-empty {
    height: auto;
    min-height: 0;
    background: var(--color-bg-alt);
    padding: var(--space-7) 0 var(--space-6);
  }

  .project-cover-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 25%;
    background-color: var(--color-bg-alt);
  }

  .project-cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(45, 42, 38, 0) 0%,
      rgba(45, 42, 38, 0.15) 50%,
      rgba(45, 42, 38, 0.8) 100%
    );
  }

  .project-cover-empty .project-cover-overlay {
    display: none;
  }

  .project-cover-content {
    position: relative;
    z-index: 1;
    color: var(--color-bg);
    padding-bottom: var(--space-6);
  }

  .project-cover-empty .project-cover-content {
    color: var(--color-text);
    padding-bottom: 0;
  }

  .project-cover-content h1 {
    color: inherit;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin: 0;
  }

  .project-cover-empty .project-cover-content h1 {
    color: var(--color-text);
  }

  .project-meta {
    color: rgba(250, 248, 243, 0.85);
    font-size: 0.95rem;
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-cover-empty .project-meta {
    color: var(--color-text-muted);
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  .project-sidebar h2 {
    font-size: 1.1rem;
    margin-top: 0;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .member-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .member-list li {
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .member-list li:last-child {
    border-bottom: none;
  }

  .member-instruments {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .member-note {
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-style: italic;
  }

  .project-links {
    margin-top: var(--space-5);
  }

  .project-links h2 {
    font-size: 1.2rem;
  }

  .back-link {
    margin-top: var(--space-6);
  }
</style>
